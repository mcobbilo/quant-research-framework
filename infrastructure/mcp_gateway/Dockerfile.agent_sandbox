# Ephemeral execution environment for the Autonomous Trading Swarm
FROM python:3.11-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    sqlite3 \
    && rm -rf /var/lib/apt/lists/*

# Install specific Data Science / Quant dependencies
# We use standard PyTorch, XGBoost, and Pandas per the Framework's requirements
RUN pip install --no-cache-dir \
    pandas \
    numpy \
    xgboost \
    torch \
    scikit-learn \
    python-dotenv

WORKDIR /workspace

# The container will be booted with a read-only volume mount of the quant_framework
# any output generated by the agent will be written to stdout or temporary directories
CMD ["python"]
